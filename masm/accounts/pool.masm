pub proc add_to_storage_item(slot_id_prefix: felt, slot_id_suffix: felt, increment_by: felt) -> felt
    dup.1 dup.1 exec.active_account::get_item
    # => [current_value, 0,0,0, prefix, suffix, increment_by]
    movup.6 add
    # => [new_value, 0,0,0, prefix, suffix]
    movdn.5 movdn.5 movdn.5 movdn.5
    # => [ prefix, suffix, new_value, 0,0,0]
    exec.native_account::set_item dropw
    ### get current value
end


pub proc sub_from_storage_item(slot_id_prefix: felt, slot_id_suffix: felt, decrement_by: felt) -> felt
    dup.1 dup.1 exec.active_account::get_item
    # => [current_value, 0,0,0, prefix, suffix, decrement_by]
    movup.6 sub
    # => [new_value, 0,0,0, prefix, suffix]
    movdn.5 movdn.5 movdn.5 movdn.5
    # => [ prefix, suffix, new_value, 0,0,0]
    exec.native_account::set_item dropw
end

const BALANCES_TEMP_VALUE = 0
#const BAL_1 = 0;
#const BAL_2 = 1;
#const BAL_3 = 2;
#const BAL_4 = 3;

pub proc sub_from_storage_item_at_idx(slot_id_prefix: felt, slot_id_suffix: felt, idx: felt, decrement_by: felt) -> felt
    dup.1 dup.1 exec.active_account::get_item mem_storew_le.BALANCES_TEMP_VALUE dropw
    # => [ prefix, suffix, idx, decrement_by]
    movup.2 dup
    # => [idx, idx, prefix, suffix, decrement_by]
    mem_load
    # => [value_at_idx, idx, prefix, suffix, decrement_by]
    movup.4 sub
    # => [new_val_at_idx, idx, prefix, suffix, ]
    swap mem_store
    # => [ prefix, suffix]
    padw mem_loadw_le.BALANCES_TEMP_VALUE
    # => [UPDATED_VALUE, prefix, suffix, ]
    movup.5 movup.5
     # => [prefix, suffix, UPDATED_VALUE]
    exec.native_account::set_item dropw
end

pub proc add_to_storage_item_at_idx(slot_id_prefix: felt, slot_id_suffix: felt, idx: felt, increment_by: felt) -> felt
    dup.1 dup.1 exec.active_account::get_item mem_storew_le.BALANCES_TEMP_VALUE dropw
    # => [ prefix, suffix, idx, increment_by]
    movup.2 dup
    # => [idx, idx, prefix, suffix, increment_by]
    mem_load
    # => [value_at_idx, idx, prefix, suffix, increment_by]
    movup.4 add
    # => [new_val_at_idx, idx, prefix, suffix, ]
    swap mem_store
    # => [ prefix, suffix]
    padw mem_loadw_le.BALANCES_TEMP_VALUE
    # => [UPDATED_VALUE, prefix, suffix, ]
    movup.5 movup.5
     # => [prefix, suffix, UPDATED_VALUE]
    exec.native_account::set_item dropw
end

pub proc get_storage_item_at_idx(slot_id_prefix: felt, slot_id_suffix: felt, idx: felt,) -> felt
    exec.active_account::get_item mem_storew_le.BALANCES_TEMP_VALUE
    # => [idx]
    mem_load
end


