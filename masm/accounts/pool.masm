# ----------------------------------------------------------------------------------------------
# SWAP
# ----------------------------------------------------------------------------------------------

pub proc execute_swap
    # => [user_key_suffix, user_key_prefix, sell_idx, sell_amount,  user_suffix, user_prefix, buy_idx, buy_amount]
    exec.operator::verfiy_signature
    # => [user_key_suffix, user_key_prefix, sell_idx, sell_amount,  user_suffix, user_prefix, buy_idx, buy_amount]
    drop drop dup.3 dup.3
    # => [user_suffix, user_prefix, sell_idx, sell_amount,  user_suffix, user_prefix, buy_idx, buy_amount]
    exec.sub_from_user_balance
    # => [BUY_KEY]
    exec.add_to_user_balance
    # => []
end

