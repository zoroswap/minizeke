SERVER_URL=127.0.0.1:7799
# Standalone process (`cargo run --bin faucet_server`) used by POST /mint.
FAUCET_SERVER_URL=127.0.0.1:7800
# Raw faucet token amount per successful request; 240 seconds matches Zeke's default.
FAUCET_MINT_AMOUNT=10000000
FAUCET_MINT_COOLDOWN_SECS=240

# Base URL. The server derives /v1/price_feeds and both price update endpoints.
ORACLE_URL=https://oracle.zoroswap.com

# Optional deploy-time asset config override.
# ASSETS_FILE=assets.toml
# Optional daily diagnostic log directory.
# LOG_DIR=logs

MIDEN_NETWORK=testnet
