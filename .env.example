SERVER_URL=127.0.0.1:7799
# Standalone process (`cargo run --bin faucet_server`) used by POST /mint.
FAUCET_SERVER_URL=127.0.0.1:7800
# Raw faucet token amount per successful request; 240 seconds matches Zeke's default.
FAUCET_MINT_AMOUNT=10000000
FAUCET_MINT_COOLDOWN_SECS=240

# Base URL. The server derives /v1/price_feeds and both price update endpoints.
ORACLE_URL=https://oracle.zoroswap.com
# Frontend-only oracle WebSocket coalescing. Internal pricing remains full rate.
ORACLE_WS_MIN_INTERVAL_MS=1000
ORACLE_WS_BPS_THRESHOLD=20

# Optional deploy-time asset config override.
# ASSETS_FILE=assets.toml
# Optional daily diagnostic log directory.
# LOG_DIR=logs
# Durable LP journal and note watcher.
# LP_DB_PATH=lp.testnet.sqlite3
# LP_CHECKPOINT_INTERVAL_SECS=600
# LP_SYNC_INTERVAL_SECS=2
# LP_MIN_DEPOSIT_AMOUNT=1

# Durable finalized curve state, analytics, dynamic fees, and wallet sessions.
# EXECUTION_DB_PATH=execution.testnet.sqlite3
# ANALYTICS_DB_PATH=analytics.testnet.sqlite3
# ANALYTICS_SYNC_INTERVAL_SECS=5
# FEE_DB_PATH=fees.testnet.sqlite3
# AUTH_DB_PATH=auth.testnet.sqlite3

# Wallet challenge/session authentication.
AUTH_DOMAIN=minizeke
AUTH_CHALLENGE_TTL_SECS=60
AUTH_SESSION_TTL_SECS=1800
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Shared only by the main server and standalone fee updater.
FEE_UPDATER_TOKEN=replace-with-a-long-random-secret
FEE_EXPIRY_CHECK_SECS=5

# Standalone `cargo run --bin fee_updater`.
FEE_SERVER_URL=http://127.0.0.1:7799
FEE_ORACLE_FEED_ID=replace-with-deployment-oracle-feed-id
FEE_REFERENCE_ASSET=ETH
SAMPLE_INTERVAL_SECS=30
EWMA_HALF_LIFE_SECS=1800
VOLATILITY_WARMUP_SAMPLES=20
MAX_SAMPLE_AGE_SECS=90
CURVE_A=-5
CURVE_B=12.4
MIN_FEE_BPS=6.5
MAX_FEE_BPS=33
UPDATE_INTERVAL_SECS=60
DEADBAND_BPS=1.5
SPIKE_RATIO=1.5
SPIKE_WINDOW_SECS=600
INITIAL_FEE_BPS=6.5
VALIDITY_PERIOD_SECS=600
REFRESH_FRACTION=0.8

MIDEN_NETWORK=testnet
